{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/halopsa-mcp",
  "title": "HaloPSA MCP",
  "description": "HaloPSA ticket triage, SLA-breach pre-emption, and cross-client analytics for any MCP agent.",
  "version": "0.2.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/halopsa/halopsa-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/halopsa"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/servosity/msp-skills/releases/download/halopsa-v0.2.1/halopsa-mcp.mcpb",
      "version": "0.2.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "HALOPSA_TENANT",
          "description": "Your HaloPSA tenant identifier.",
          "isRequired": true,
          "isSecret": false
        },
        {
          "name": "HALOPSA_CLIENT_ID",
          "description": "OAuth2 client_credentials ID from Configuration \u2192 Integrations \u2192 Halo PSA API.",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "HALOPSA_CLIENT_SECRET",
          "description": "OAuth2 client_credentials secret.",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "HALOPSA_DOMAIN",
          "description": "Domain template variable. Defaults to halopsa.com.",
          "isRequired": false,
          "isSecret": false,
          "default": "halopsa.com"
        }
      ]
    }
  ]
}
