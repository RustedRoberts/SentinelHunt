{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/tactical-rmm-mcp",
  "title": "Tactical RMM MCP",
  "description": "Every Tactical RMM endpoint as a typed command, plus an offline SQLite mirror and cross-entity",
  "version": "0.1.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/tactical-rmm/tactical-rmm-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/tactical-rmm"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/servosity/msp-skills/releases/download/tactical-rmm-v0.1.1/tactical-rmm-mcp.mcpb",
      "version": "0.1.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "TRMM_API_KEY",
          "description": "Set the TRMM_API_KEY credential for the Tactical RMM MCP server.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
