{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/betterstack-mcp",
  "title": "Better Stack MCP",
  "description": "Every Better Stack Uptime feature, plus an offline SQLite mirror and cross-resource fleet analytics",
