      "version": "0.1.2",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SUPEROPS_API_TOKEN",
          "description": "Set the SUPEROPS_API_TOKEN credential for the SuperOps MCP server.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
