{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/superops-mcp",
  "title": "SuperOps MCP",
  "description": "Every SuperOps PSA+RMM entity in your terminal, plus a local SQLite mirror that answers",
  "version": "0.1.2",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/superops/superops-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/superops"
  },
  "packages": [
    {
      "registryType": "mcpb",
