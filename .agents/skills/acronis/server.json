{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/acronis-mcp",
  "title": "Acronis MCP",
  "description": "The first real CLI for the Acronis Cyber Protect Cloud platform  -  every tenant, agent, and usage",
  "version": "0.1.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/acronis/acronis-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/acronis"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/servosity/msp-skills/releases/download/acronis-v0.1.1/acronis-mcp.mcpb",
      "version": "0.1.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "ACRONIS_DATACENTER",
          "description": "Acronis datacenter host prefix (for example eu2-cloud or us-cloud).",
          "isRequired": false,
          "isSecret": false
        }
      ]
    }
  ]
}
