{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/gradient-mcp",
  "title": "Gradient MSP MCP",
  "description": "CLI and MCP server for Gradient MSP Synthesize: usage push, billing drift, alert tracing.",
  "version": "0.1.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/gradient/gradient-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/gradient"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/servosity/msp-skills/releases/download/gradient-v0.1.1/gradient-mcp.mcpb",
      "version": "0.1.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "GRADIENT_TOKEN",
          "description": "Set the GRADIENT_TOKEN credential for the Gradient MSP MCP server.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
