{
  "manifest_version": "0.3",
  "name": "knowbe4-mcp",
  "display_name": "KnowBe4",
  "version": "0.1.1",
  "description": "Every KnowBe4 KMSAT reporting feature, plus a local SQLite store for the questions the console cannot answer.",
  "author": {
    "name": "Servosity Inc."
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/knowbe4-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/knowbe4-mcp",
      "args": [],
      "env": {
        "KNOWBE4_API_KEY": "${user_config.knowbe4_api_key}",
        "KNOWBE4_REGION": "${user_config.knowbe4_region}"
      }
    }
  },
  "user_config": {
    "knowbe4_api_key": {
      "type": "string",
      "title": "KNOWBE4_API_KEY",
      "description": "Sets KNOWBE4_API_KEY for the KnowBe4 MCP server. Get a credential from https://developer.knowbe4.com/.",
      "sensitive": true,
      "required": true
    },
    "knowbe4_region": {
      "type": "string",
      "title": "KNOWBE4_REGION",
      "description": "Sets KNOWBE4_REGION for the endpoint template variable {region}.",
      "default": "us"
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  },
  "printing_press_version": "4.24.0",
  "press_provenance": {
    "printing_press_version": "4.24.0",
    "generated_at": "2026-06-13T04:06:30.709989Z",
