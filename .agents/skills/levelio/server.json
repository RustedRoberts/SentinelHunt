{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/levelio-mcp",
  "title": "Level MCP",
  "description": "Every Level RMM endpoint, plus a local SQLite fleet store and offline cross-entity rollups no Level",
  "version": "0.1.1",
  "icons": [
