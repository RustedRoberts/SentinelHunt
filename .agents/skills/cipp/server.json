{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/cipp-mcp",
  "title": "CIPP MCP",
  "description": "First single-binary CLI for CIPP  -  offline SQLite store, fleet posture analytics, and",
  "version": "0.1.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/cipp/cipp-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/cipp"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/servosity/msp-skills/releases/download/cipp-v0.1.1/cipp-mcp.mcpb",
      "version": "0.1.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "CIPP_API_KEY",
          "description": "Set the CIPP_API_KEY credential for the CIPP MCP server.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
