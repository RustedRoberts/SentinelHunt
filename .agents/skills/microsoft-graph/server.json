{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/microsoft-graph-mcp",
  "title": "Microsoft Graph MCP",
  "description": "The maintained single-binary successor to the retiring mgc  -  every MSP-relevant Microsoft Graph",
  "version": "0.1.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/microsoft-graph/microsoft-graph-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/microsoft-graph"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/servosity/msp-skills/releases/download/microsoft-graph-v0.1.1/microsoft-graph-mcp.mcpb",
      "version": "0.1.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "MICROSOFT_GRAPH_TOKEN",
          "description": "Set the MICROSOFT_GRAPH_TOKEN credential for the Microsoft Graph MCP server.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
