{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/afi-mcp",
  "title": "Afi MCP",
  "description": "The first CLI for Afi SaaS backup  -  full public-API coverage plus the fleet-wide coverage",
  "version": "0.1.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/afi/afi-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/afi"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/servosity/msp-skills/releases/download/afi-v0.1.1/afi-mcp.mcpb",
      "version": "0.1.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "AFI_API_KEY",
          "description": "Set the AFI_API_KEY credential for the Afi MCP server.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
