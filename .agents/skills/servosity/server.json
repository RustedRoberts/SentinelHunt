      "version": "0.3.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "SERVOSITY_MSP_TOKEN",
          "description": "Servosity partner API token from the partner portal. Scoped to your reseller account only.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
