{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/servosity-mcp",
  "title": "Servosity MCP",
  "description": "Fleet-wide backup triage, stale-backup detection, and cross-engine analytics for any MCP agent.",
  "version": "0.3.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/servosity/servosity-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/servosity"
  },
  "packages": [
    {
      "registryType": "mcpb",
