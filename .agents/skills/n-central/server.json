{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/n-central-mcp",
  "title": "N-able N-central MCP",
  "description": "N-central REST API with an offline org-tree mirror, cross-tenant search, and a JWT-expiry guardian.",
  "version": "0.1.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/n-central/n-central-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/n-central"
  },
  "packages": [
    {
      "registryType": "mcpb",
