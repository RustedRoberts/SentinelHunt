{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Servosity/pipedrive-mcp",
  "title": "Pipedrive MCP",
  "description": "Full Pipedrive CRUD plus a local SQLite pipeline copy: stale deals, forecasts, aging, dupes, rep",
  "version": "0.1.1",
  "icons": [
    {
      "src": "https://raw.githubusercontent.com/servosity/msp-skills/main/docs/assets/social/pipedrive/pipedrive-512x512.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "repository": {
    "url": "https://github.com/servosity/msp-skills",
    "source": "github",
    "subfolder": "skills/pipedrive"
  },
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/servosity/msp-skills/releases/download/pipedrive-v0.1.1/pipedrive-mcp.mcpb",
      "version": "0.1.1",
      "fileSha256": "PLACEHOLDER_SHA256_FILLED_BY_CI",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "PIPEDRIVE_API_KEY",
          "description": "Set the PIPEDRIVE_API_KEY credential for the Pipedrive MCP server.",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
